---
import { site, footerLinks } from "@data/site";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  eyebrow?: string;
}

const {
  title = site.name,
  description = site.description,
  eyebrow = "Smart cities, sustainable infrastructure, digital built environment"
} = Astro.props;

const pageTitle = title === site.name ? title : `${title} | ${site.shortName}`;
const isEnglishPath = Astro.url.pathname === "/en/" || Astro.url.pathname.startsWith("/en/");
const pathPrefix = isEnglishPath ? "/en" : "";
const localHref = (href: string) => href === "/" ? `${pathPrefix}/` : `${pathPrefix}${href}`;
const canonicalUrl = new URL(Astro.url.pathname, site.reviewDomain).toString();
const imageUrl = new URL(site.defaultImage, site.reviewDomain).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="keywords" content={site.keywords.join(", ")} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#084f50" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.shortName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <header class="site-header">
      <div class="shell nav-shell">
        <a class="brand" href={localHref("/")} aria-label={`${site.shortName} home`}>
          <img class="brand-logo" src="/images/scsda-logo.jpg" alt="SCSDA logo" />
          <span>
            <strong>{site.shortName}</strong>
            <small>{site.name}</small>
          </span>
        </a>
        <nav class="main-nav" aria-label="Main navigation">
          {site.nav.map((item) => <a href={localHref(item.href)}>{item.label}</a>)}
        </nav>
      </div>
    </header>
    <main id="content">
      <slot name="hero">
        <section class="page-hero">
          <div class="shell narrow">
            <p class="eyebrow">{eyebrow}</p>
            <h1>{title}</h1>
            <p>{description}</p>
          </div>
        </section>
      </slot>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="shell footer-grid">
        <div>
          <p class="footer-kicker">{site.shortName}</p>
          <p>
            Research, education, and applied innovation for smart cities,
            digital built environments, and sustainable infrastructure.
          </p>
        </div>
        <div>
          <p class="footer-kicker">Official domain</p>
          <p><a href={site.reviewDomain}>{site.reviewDomain}</a></p>
          <p class="muted">English mirror path: {site.canonicalFutureDomain}</p>
        </div>
        <div>
          <p class="footer-kicker">Links</p>
          <ul class="footer-links">
            {footerLinks.map((item) => <li><a href={localHref(item.href)}>{item.label}</a></li>)}
          </ul>
        </div>
      </div>
    </footer>
  </body>
</html>
