---
import BaseLayout from "../layouts/BaseLayout.astro";
import { institutionalPrinciples, platformMetrics } from "@data/site";
import { researchCentres } from "@data/research";
---

<BaseLayout
  title="About SCSDA"
  description="SCSDA is a nonprofit applied research academy focused on smart cities, sustainable development, digital built environments, sensing technologies, and smart infrastructure. The Academy presents public research themes, selected platform-construction records, and applied project summaries for international academic and industry audiences."
>
  <section class="section">
    <div class="shell article narrow">
      <p class="eyebrow">Institutional Background</p>
      <h2>A research platform for smart cities and sustainable development.</h2>
      <p>
        Smart Cities and Sustainable Development Academy, or SCSDA, was
        established in Chongqing in 2019 as a nonprofit applied research
        organization. Its work connects interdisciplinary research, engineering
        validation, education-oriented knowledge exchange, and industry-facing
        collaboration. The Academy is positioned around the built environment:
        how cities, infrastructure, buildings, sensing systems, construction
        data, and sustainable materials can be studied together through applied
        research and public-facing project communication.
      </p>
      <p>
        The Academy's public research areas include digital built environments,
        BIM and digital twins, MEMS sensing and AIoT, smart infrastructure,
        intelligent monitoring systems, sustainable materials, and urban
        analytics. During its platform-construction period, SCSDA developed a
        structure of research centres and laboratories, coordinated experts and
        enterprise-facing collaboration, and produced selected public outputs
        across research, application, training, and technology demonstration.
        Together, these records show the Academy's scope, methods, and
        institutional development for academic, industry, and institutional
        audiences.
      </p>
    </div>
  </section>

  <section class="section surface">
    <div class="shell section-heading">
      <div>
        <p class="eyebrow">Mission</p>
        <h2>Research, education, and responsible applied innovation.</h2>
      </div>
      <p>
        SCSDA aims to connect scientific research with practical engineering
        problems in the built environment. Its mission is to support applied
        research capacity, education-oriented knowledge exchange, and
        responsible technology translation across smart cities and sustainable
        infrastructure. The Academy communicates its public record through
        clear, public-facing, and non-confidential summaries so that its work
        can be understood by academic collaborators, industry partners, and
        international institutional audiences in a measured tone.
      </p>
    </div>
    <div class="shell claim-grid">
      {institutionalPrinciples.map((item) => (
        <article class="claim-card">
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="interview-record" class="section">
    <div class="shell split">
      <div class="article">
        <p class="eyebrow">Interview Record</p>
        <h2>Institutional interview record.</h2>
        <p>
          This short media record presents SCSDA's institutional development,
          applied research engagement, and smart-city-oriented platform
          building. It is included as part of the Academy's public record,
          alongside research-centre material, platform indicators, and selected
          applied project summaries.
        </p>
        <p>
          Longer project details are summarised on the research and project
          pages. The video complements those summaries as a compact
          institutional media record.
        </p>
      </div>
      <figure class="video-panel">
        <video
          controls
          preload="metadata"
          poster="/images/han-scsda-interview-poster.jpg"
          src="/media/han-scsda-interview.mp4"
        >
          Your browser does not support embedded video.
        </video>
        <figcaption class="image-caption">
          Interview video preserved as a short public record of SCSDA-related
          institutional and research engagement.
        </figcaption>
      </figure>
    </div>
  </section>

  <section class="section">
    <div class="shell section-heading">
      <div>
        <p class="eyebrow">Platform Structure</p>
        <h2>Research centres and laboratories developed during 2019-2023.</h2>
      </div>
      <p>
        The Academy's platform-construction period brought together research
        centres and laboratories across sensing, digital construction, smart
        infrastructure, sustainable materials, and intelligent equipment. The
        structure helps present SCSDA as a multi-theme applied research
        platform: each centre connects a technical domain with public research
        communication, education engagement, and selected engineering
        demonstrators.
      </p>
    </div>
    <div class="shell centre-grid">
      {researchCentres.map((centre) => (
        <article class="centre-card">{centre}</article>
      ))}
    </div>
  </section>

  <section class="section surface">
    <div class="shell metric-grid">
      {platformMetrics.map((metric) => (
        <article class="metric">
          <strong>{metric.value}</strong>
          <span>{metric.label}</span>
          <p>{metric.detail}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
