---
import BaseLayout from "../layouts/BaseLayout.astro";
import { institutionalPrinciples, platformMetrics } from "@data/site";
import { researchCentres } from "@data/research";
---

<BaseLayout
  title="About SCSDA"
  description="SCSDA is a nonprofit applied research academy focused on smart cities, sustainable development, digital built environments, sensing technologies, and smart infrastructure."
>
  <section class="section">
    <div class="shell split">
      <div class="article">
        <p class="eyebrow">Institutional Background</p>
        <h2>A research platform for smart cities and sustainable development.</h2>
        <p>
          Smart Cities and Sustainable Development Academy, or SCSDA, was
          established in Chongqing in 2019 as a nonprofit applied research
          organization. Its work connects interdisciplinary research,
          engineering validation, education-oriented knowledge exchange, and
          industry-facing collaboration.
        </p>
        <p>
          The Academy's public research areas include digital built
          environments, BIM and digital twins, MEMS sensing and AIoT, smart
          infrastructure, intelligent monitoring systems, sustainable materials,
          and urban analytics.
        </p>
      </div>
      <figure class="image-panel">
        <img src="/images/research-space.jpg" alt="SCSDA research and meeting space" />
        <figcaption class="image-caption">
          Research and meeting space preserved from public SCSDA materials.
        </figcaption>
      </figure>
    </div>
  </section>

  <section class="section surface">
    <div class="shell section-heading">
      <div>
        <p class="eyebrow">Mission</p>
        <h2>Research, education, and responsible applied innovation.</h2>
      </div>
      <p>
        SCSDA aims to connect scientific research with practical engineering
        problems in the built environment, while communicating its work through
        clear, public-facing, and non-confidential summaries.
      </p>
    </div>
    <div class="shell claim-grid">
      {institutionalPrinciples.map((item) => (
        <article class="claim-card">
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="shell section-heading">
      <div>
        <p class="eyebrow">Platform Structure</p>
        <h2>Research centres and laboratories reported during 2019-2023.</h2>
      </div>
      <p>
        The Academy's implementation report recorded 12 research centres and
        laboratories during the platform-construction period. These names are
        included as historical institutional structure, not as a current
        staffing or operational-scale claim.
      </p>
    </div>
    <div class="shell centre-grid">
      {researchCentres.map((centre) => (
        <article class="centre-card">{centre}</article>
      ))}
    </div>
  </section>

  <section class="section surface">
    <div class="shell metric-grid">
      {platformMetrics.map((metric) => (
        <article class="metric">
          <strong>{metric.value}</strong>
          <span>{metric.label}</span>
          <p>{metric.detail}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
