---
import BaseLayout from "../layouts/BaseLayout.astro";
import { institutionalPrinciples, platformMetrics, site } from "@data/site";
import { caseStudies, researchThemes } from "@data/research";

interface Props {
  pathPrefix?: string;
}

const { pathPrefix = "" } = Astro.props;
const pageHref = (href: string) => `${pathPrefix}${href}`;
---

<BaseLayout title={site.name} description={site.tagline}>
  <section
    slot="hero"
    class="hero"
    style={`--hero-image: url('/images/academy-launch.jpg')`}
  >
    <div class="shell hero-content">
      <p class="eyebrow">Applied research academy established in Chongqing in 2019</p>
      <h1>Smart Cities and Sustainable Development Academy</h1>
      <p class="lead">
        Research, education, and applied innovation in smart cities, digital
        built environments, smart infrastructure, sensing technologies, and
        sustainable urban systems.
      </p>
      <div class="hero-actions">
        <a class="button primary" href={pageHref("/about/")}>About SCSDA</a>
        <a class="button ghost" href={pageHref("/research/")}>Research Themes</a>
        <a class="button ghost" href={pageHref("/projects/")}>Selected Projects</a>
      </div>
    </div>
  </section>

  <section class="section surface">
    <div class="shell section-heading">
      <div>
        <p class="eyebrow">Institutional Profile</p>
        <h2>A nonprofit applied research academy for smart cities and sustainable development.</h2>
      </div>
      <p>
        SCSDA was established in Chongqing in 2019. The Academy's work is best
        understood as an interdisciplinary applied-research platform linking
        digital built environments, smart infrastructure, sensing technologies,
        sustainable construction, and international knowledge exchange.
      </p>
    </div>
    <div class="shell metric-grid">
      {platformMetrics.map((metric) => (
        <article class="metric">
          <strong>{metric.value}</strong>
          <span>{metric.label}</span>
          <p>{metric.detail}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="shell split">
      <div class="article">
        <p class="eyebrow">Platform Development</p>
        <h2>Connecting research themes with engineering practice.</h2>
        <p>
          The Academy developed a portfolio of research centres and applied R&D
          activities across BIM, digital twins, MEMS sensing, smart
          infrastructure, intelligent monitoring, sustainable materials, and
          urban systems.
        </p>
        <p>
          Its public record shows a platform-building approach: forming research
          centres, coordinating academic and enterprise partners, translating
          research ideas into demonstrators and engineering studies, and
          supporting education-oriented knowledge exchange.
        </p>
      </div>
      <figure class="image-panel">
        <img
          src="/images/research-exhibition.jpg"
          alt="SCSDA research exhibition and smart infrastructure display"
        />
        <figcaption class="image-caption">
          Public SCSDA display material showing smart infrastructure and
          research-centre work.
        </figcaption>
      </figure>
    </div>
  </section>

  <section class="section tint">
    <div class="shell section-heading">
      <div>
        <p class="eyebrow">Research Areas</p>
        <h2>Digital built environment, smart infrastructure, sensing, and sustainable cities.</h2>
      </div>
      <p>
        SCSDA's research themes connect engineering methods with urban systems:
        from BIM and point-cloud analysis to MEMS sensing, AIoT, green
        construction, and data-driven infrastructure workflows.
      </p>
    </div>
    <div class="shell theme-grid">
      {researchThemes.slice(0, 4).map((theme) => (
        <article class="theme-card">
          <h3>{theme.title}</h3>
          <p>{theme.summary}</p>
          <p class="theme-note">{theme.scope}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section surface">
    <div class="shell section-heading">
      <div>
        <p class="eyebrow">Selected Work</p>
        <h2>Public-facing examples of applied research and platform construction.</h2>
      </div>
      <p>
        The examples below are selected because they communicate SCSDA's work
        clearly to international academic and research collaborators through
        concise, non-confidential project descriptions.
      </p>
    </div>
    <div class="shell case-grid">
      {caseStudies.slice(0, 2).map((item) => (
        <article class="case-card">
          <img src={item.image} alt={`${item.title} visual record`} />
          <div class="case-body">
            <span class="category">{item.category}</span>
            <h3>{item.title}</h3>
            <p>{item.summary}</p>
            <ul class="clean-list">
              {item.highlights.map((highlight) => <li>{highlight}</li>)}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section tight">
    <div class="shell claim-grid">
      {institutionalPrinciples.map((item) => (
        <article class="claim-card">
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
