---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site, platformMetrics, safeClaims } from "@data/site";
import { researchThemes, caseStudies } from "@data/research";
---

<BaseLayout title={site.name} description={site.tagline}>
  <section
    slot="hero"
    class="hero"
    style={`--hero-image: url('/images/lab-engagement.jpg')`}
  >
    <div class="shell hero-content">
      <p class="eyebrow">Non-confidential research portfolio</p>
      <h1>Smart Cities and Sustainable Development Academy</h1>
      <p class="lead">
        A nonprofit applied research platform for smart cities, digital built
        environments, smart infrastructure, and sustainable urban systems.
      </p>
      <div class="hero-actions">
        <a class="button primary" href="/leadership/">Dr Han's leadership role</a>
        <a class="button ghost" href="/research/">Research themes</a>
      </div>
    </div>
  </section>

  <section class="section surface">
    <div class="shell section-heading">
      <div>
        <p class="eyebrow">Purpose</p>
        <h2>Institutional evidence, written for international academic review.</h2>
      </div>
      <p>
        This English site presents SCSDA as an institutional research platform,
        while making clear Dr Daguang Han's founding and executive leadership in
        the Academy's early platform-construction period.
      </p>
    </div>
    <div class="shell metric-grid">
      {platformMetrics.map((metric) => (
        <article class="metric">
          <strong>{metric.value}</strong>
          <span>{metric.label}</span>
          <p>{metric.detail}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="shell split">
      <div class="article">
        <p class="eyebrow">Leadership evidence</p>
        <h2>Built around platform leadership, not personal promotion.</h2>
        <p>
          SCSDA is presented as a research-organization website. Its UK-facing
          value is that it documents how Dr Han helped build and coordinate a
          research platform across BIM, digital twins, sensing, smart
          infrastructure and sustainable urban systems.
        </p>
        <div class="callout">
          During SCSDA's early platform-construction period, Dr Daguang Han
          served as the principal responsible person and founding executive
          lead, coordinating research-centre development, international expert
          engagement, enterprise-facing applied research, and public
          research-platform delivery.
        </div>
      </div>
      <figure class="image-panel">
        <img
          src="/images/platform-bridge-bim.png"
          alt="BIM and bridge engineering analysis from the preserved SCSDA public site"
        />
        <figcaption class="image-caption">
          Preserved public visual material from the earlier Chinese SCSDA site.
        </figcaption>
      </figure>
    </div>
  </section>

  <section class="section tint">
    <div class="shell section-heading">
      <div>
        <p class="eyebrow">Research themes</p>
        <h2>Digital built environment, smart infrastructure and sustainable cities.</h2>
      </div>
      <p>
        The site foregrounds research areas that align with UK and European
        academic posts in digital construction, construction informatics,
        infrastructure resilience and sustainable urban systems.
      </p>
    </div>
    <div class="shell theme-grid">
      {researchThemes.slice(0, 4).map((theme) => (
        <article class="theme-card">
          <h3>{theme.title}</h3>
          <p>{theme.summary}</p>
          <p class="evidence">{theme.evidence}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section surface">
    <div class="shell section-heading">
      <div>
        <p class="eyebrow">Selected case studies</p>
        <h2>Public-facing examples of applied research platform development.</h2>
      </div>
      <p>
        These examples are intentionally limited to public, non-confidential
        summaries. Sensitive or security-adjacent topics from older records are
        not foregrounded on the English site.
      </p>
    </div>
    <div class="shell case-grid">
      {caseStudies.slice(0, 2).map((item) => (
        <article class="case-card">
          <img src={item.image} alt={`${item.title} visual evidence`} />
          <div class="case-body">
            <span class="category">{item.category}</span>
            <h3>{item.title}</h3>
            <p>{item.summary}</p>
            <ul class="clean-list">
              {item.highlights.map((highlight) => <li>{highlight}</li>)}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section tight">
    <div class="shell claim-grid">
      {safeClaims.map((claim) => (
        <article class="claim-card">
          <h3>{claim}</h3>
          <p>
            This claim is intended for a cautious international audience and is
            mapped to preserved website materials, the implementation report or
            Dr Han's verified academic profile.
          </p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
