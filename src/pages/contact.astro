---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "@data/site";

interface Props {
  pathPrefix?: string;
}

const { pathPrefix = "" } = Astro.props;
const pageHref = (href: string) => `${pathPrefix}${href}`;
---

<BaseLayout
  title="Contact"
  description="Institutional contact details for SCSDA-related research and collaboration enquiries."
>
  <section class="section">
    <div class="shell split">
      <div class="article">
        <p class="eyebrow">Enquiries</p>
        <h2>Research and collaboration contact.</h2>
        <p>
          For SCSDA-related academic, research, education, or collaboration
          enquiries, contact the Academy through the institutional email below.
        </p>
        <p>
          <a class="button" href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a>
        </p>
        <div class="profile-links">
          <a href={pageHref("/message/")}>Send a website message</a>
          <a href={pageHref("/join/")}>Join Us / opportunities</a>
        </div>
      </div>
      <div class="output-card">
        <h3>Institutional Contact Scope</h3>
        <p>SCSDA welcomes public-facing, non-confidential enquiries related to:</p>
        <ul class="clean-list">
          <li>smart cities and sustainable development research</li>
          <li>digital built environment, BIM, digital twins and sensing</li>
          <li>education, training, workshops and academic engagement</li>
          <li>non-confidential applied research and collaboration summaries</li>
        </ul>
        <p class="muted">
          Leadership background and academic-profile references are kept on the
          Leadership page, separate from this institutional contact channel.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
