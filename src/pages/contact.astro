---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "@data/site";
---

<BaseLayout
  title="Contact"
  description="Contact and academic profile links for SCSDA-related research and collaboration enquiries."
>
  <section class="section">
    <div class="shell split">
      <div class="article">
        <p class="eyebrow">Enquiries</p>
        <h2>Research and collaboration contact.</h2>
        <p>
          For SCSDA-related academic, research, education, or collaboration
          enquiries, contact Dr Daguang Han through the email below or through
          verified academic profile pages.
        </p>
        <p>
          <a class="button" href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a>
        </p>
      </div>
      <div class="output-card">
        <h3>Profile Links</h3>
        <p class="profile-affiliation compact">
          <span>Current academic affiliation</span>
          <strong>{site.academicAffiliation}</strong>
        </p>
        <div class="profile-links">
          {site.profiles.map((profile) => (
            <a href={profile.href} target="_blank" rel="noreferrer">{profile.label}</a>
          ))}
        </div>
        <p class="muted">
          SCSDA-related enquiries are handled through email and verified
          academic profile pages.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
