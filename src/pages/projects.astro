---
import BaseLayout from "../layouts/BaseLayout.astro";
import { caseStudies, engineeringMonitoringDemonstrators } from "@data/research";
---

<BaseLayout
  title="Selected Projects"
  description="Selected public-facing SCSDA project summaries in BIM, digital twins, reality capture, MEMS sensing, smart infrastructure, and sustainable urban systems."
>
  <section class="section">
    <div class="shell section-heading">
      <div>
        <p class="eyebrow">Projects and Case Studies</p>
        <h2>Public summaries of platform construction and applied research.</h2>
      </div>
      <p>
        These examples are selected from public and non-confidential material.
        They show the Academy's work across research-centre development,
        engineering validation, training, digital construction, and sensing
        applications. Together they make the platform more legible: SCSDA's
        work is not presented as isolated consultancy, but as applied research
        activity that connects research agendas, demonstrators, technical
        systems, partner-facing collaboration, and education-oriented
        knowledge exchange.
      </p>
    </div>
    <div class="shell theme-grid">
      {caseStudies.map((item) => (
        <article class="theme-card">
          <span class="category">{item.category}</span>
          <h3>{item.title}</h3>
          <p>{item.summary}</p>
          <ul class="clean-list">
            {item.highlights.map((highlight) => <li>{highlight}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="section surface">
    <div class="shell section-heading">
      <div>
        <p class="eyebrow">Product and Prototype Material</p>
        <h2>Applied monitoring, sensing, and environmental demonstrators.</h2>
      </div>
      <p>
        Public product-brochure visuals preserved from SCSDA-related materials
        show applied work around sensing, site monitoring, infrastructure
        safety, VOCs sensing, and indoor-environment data. The examples below
        are presented as research and engineering demonstrators. Their value is
        that they show a pathway from technical concept to field context:
        sensing hardware, monitoring architecture, platform interfaces, and
        engineering deployment scenarios are described together for
        international academic and industry audiences.
      </p>
    </div>
    <div class="shell product-grid">
      {engineeringMonitoringDemonstrators.map((item) => (
        <article class="case-card product-card">
          <img src={item.image} alt={`${item.title} visual material`} />
          <div class="case-body">
            <span class="category">{item.category}</span>
            <h3>{item.title}</h3>
            <p>{item.summary}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section surface">
    <div class="shell article narrow">
      <p class="eyebrow">Public Scope</p>
      <h2>Non-confidential project communication.</h2>
      <p>
        SCSDA's project pages describe research directions, engineering
        methods, demonstrators, and selected outcomes through concise,
        public-facing, and non-confidential summaries. The emphasis is on what
        the Academy can responsibly show: applied research questions, platform
        capabilities, technical workflows, and public records of research
        development across digital construction and smart infrastructure.
      </p>
    </div>
  </section>
</BaseLayout>
