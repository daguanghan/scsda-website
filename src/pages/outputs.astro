---
import BaseLayout from "../layouts/BaseLayout.astro";
import { constructionPeriodIndicators, selectedOutputs } from "@data/research";
---

<BaseLayout
  title="Outputs"
  description="Selected SCSDA outputs, applied research directions, and platform-building indicators from the 2019-2023 construction period."
>
  <section class="section">
    <div class="shell section-heading">
      <div>
        <p class="eyebrow">2019-2023 Platform Construction</p>
        <h2>Selected research, platform-building, and applied R&D outputs.</h2>
      </div>
      <p>
        SCSDA's output record is presented as a platform-development profile:
        research centres, applied R&D directions, publications, intellectual
        property, training activity, and incubation work are grouped to show
        how the Academy combined academic, technical, and industry-facing
        activity during its construction period.
      </p>
    </div>
    <div class="shell output-grid">
      {selectedOutputs.map((group) => (
        <article class="output-card">
          <h3>{group.group}</h3>
          <ul class="clean-list">
            {group.items.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="section surface">
    <div class="shell section-heading">
      <div>
        <p class="eyebrow">Construction-Period Indicators</p>
        <h2>Additional institutional indicators from platform construction.</h2>
      </div>
      <p>
        These indicators are useful because they show organisational scale in a
        measured way: people, papers, intellectual-property outputs, applied
        R&D projects, and incubation activity are presented as reported
        platform-construction records with clear period context.
      </p>
    </div>
    <div class="shell metric-grid">
      {constructionPeriodIndicators.map((metric) => (
        <article class="metric">
          <strong>{metric.value}</strong>
          <span>{metric.label}</span>
          <p>{metric.detail}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="shell article narrow">
      <p class="eyebrow">Outputs in Context</p>
      <h2>Research outputs are linked to platform development.</h2>
      <p>
        SCSDA's outputs combine research publications, intellectual property,
        applied R&D, training, research-centre formation, and incubation
        activity. The Academy's value lies in linking these outputs through an
        applied research platform rather than treating them as isolated
        deliverables. This is the clearest institutional story for the English
        website: an applied academy developed research themes, built centres,
        supported projects, and communicated selected outcomes in areas
        relevant to smart cities, digital construction, sensing, and
        sustainable infrastructure.
      </p>
    </div>
  </section>
</BaseLayout>
