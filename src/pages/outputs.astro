---
import BaseLayout from "../layouts/BaseLayout.astro";
import { constructionPeriodIndicators, selectedOutputs } from "@data/research";
---

<BaseLayout
  title="Outputs"
  description="Selected SCSDA construction-period outputs, applied research directions, and platform-building indicators reported for 2019-2023."
>
  <section class="section">
    <div class="shell section-heading">
      <div>
        <p class="eyebrow">Outputs</p>
        <h2>Selected research, platform-building, and applied R&D outputs.</h2>
      </div>
      <p>
        The figures on this page are period-labelled and should be read as
        reported outputs for the 2019-2023 platform-construction period.
      </p>
    </div>
    <div class="shell output-grid">
      {selectedOutputs.map((group) => (
        <article class="output-card">
          <h3>{group.group}</h3>
          <ul class="clean-list">
            {group.items.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="section surface">
    <div class="shell section-heading">
      <div>
        <p class="eyebrow">Construction-Period Indicators</p>
        <h2>Additional institutional indicators reported in the implementation record.</h2>
      </div>
      <p>
        These indicators help describe the scale of SCSDA's construction-period
        platform activity. They are not presented as current staffing,
        enrollment, or operational-scale claims.
      </p>
    </div>
    <div class="shell metric-grid">
      {constructionPeriodIndicators.map((metric) => (
        <article class="metric">
          <strong>{metric.value}</strong>
          <span>{metric.label}</span>
          <p>{metric.detail}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="shell split">
      <figure class="image-panel">
        <img
          src="/images/bim-prefabrication.jpg"
          alt="BIM-based prefabrication and point-cloud analysis"
        />
        <figcaption class="image-caption">
          Public SCSDA visual material on BIM-based prefabrication and digital
          measurement.
        </figcaption>
      </figure>
      <div class="article">
        <p class="eyebrow">Outputs in Context</p>
        <h2>Research outputs are linked to platform development.</h2>
        <p>
          SCSDA's reported outputs combine research publications, intellectual
          property, applied R&D, training, research-centre formation, and
          incubation activity. The Academy's value lies in linking these
          outputs through an applied research platform rather than treating
          them as isolated deliverables.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
