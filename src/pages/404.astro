        <a href="/">Home</a>
        <a href="/en/">English site</a>
        <a href="/en/leadership/">Leadership</a>
        <a href="/en/research/">Research</a>
        <a href="/en/projects/">Projects</a>
        <a href="/en/join/">Join Us</a>
        <a href="/en/message/">Message</a>
        <a href="/en/contact/">Contact</a>
      </div>
    </div>
  </section>
</BaseLayout>
