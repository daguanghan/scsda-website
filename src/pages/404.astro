---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Page Not Found"
  description="The requested SCSDA page could not be found."
>
  <section class="section">
    <div class="shell article narrow">
      <p class="eyebrow">404</p>
      <h2>The page you requested is not available.</h2>
      <p>
        The SCSDA English site is being prepared as a public-facing research
        portfolio. Use the links below to return to the main sections.
      </p>
      <div class="profile-links">
        <a href="/">Home</a>
        <a href="/en/">English site</a>
        <a href="/en/leadership/">Leadership</a>
        <a href="/en/research/">Research</a>
        <a href="/en/contact/">Contact</a>
      </div>
    </div>
  </section>
</BaseLayout>
