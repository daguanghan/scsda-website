---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "@data/site";
import { leadershipResponsibilities } from "@data/research";
---

<BaseLayout
  title="Leadership"
  description="SCSDA was initiated and led by Dr Daguang Han during its platform-construction period, with responsibilities across strategic planning, research-centre development, collaboration, and applied project delivery."
>
  <section class="section">
    <div class="shell split reverse">
      <figure class="image-panel">
        <img
          src="/images/lab-engagement.jpg"
          alt="Public visual record of SCSDA research engagement"
        />
        <figcaption class="image-caption">
          Public SCSDA visual record of research engagement and laboratory work.
        </figcaption>
      </figure>
      <div class="article">
        <p class="eyebrow">Founding Leadership</p>
        <h2>Dr Daguang Han's role in building SCSDA.</h2>
        <p>
          SCSDA was initiated and led by Dr Daguang Han during the Academy's
          platform-construction period. His role covered institutional
          planning, research-centre development, international academic links,
          enterprise engagement, and the delivery of applied research projects.
        </p>
        <p>
          The public implementation record identifies Dr Han as the responsible
          person for the Academy's platform-construction project. The wording on
          this website therefore presents his leadership in a formal,
          institution-facing way: founder, founding executive leader, and
          coordinator of the Academy's early research platform.
        </p>
      </div>
    </div>
  </section>

  <section class="section surface">
    <div class="shell section-heading">
      <div>
        <p class="eyebrow">Leadership Scope</p>
        <h2>Strategic, academic, and industry-facing responsibilities.</h2>
      </div>
      <p>
        The Academy's early development required more than topic-level research:
        it required agenda-setting, partner development, project formation,
        expert engagement, institutional reporting, and public communication.
      </p>
    </div>
    <div class="shell theme-grid">
      {leadershipResponsibilities.map((item) => (
        <article class="theme-card">
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="shell split">
      <div class="article">
        <p class="eyebrow">Public Profile Links</p>
        <h2>Academic identity remains connected to verified external profiles.</h2>
        <p>
          This institutional website presents SCSDA's platform and Dr Han's
          role within it. Broader personal academic records, publications, and
          profile details should be checked through verified academic channels.
        </p>
        <div class="profile-links">
          {site.profiles.map((profile) => (
            <a href={profile.href} target="_blank" rel="noreferrer">{profile.label}</a>
          ))}
        </div>
      </div>
      <figure class="image-panel">
        <img
          src="/images/research-exhibition.jpg"
          alt="SCSDA research display and institutional visit"
        />
        <figcaption class="image-caption">
          Public display material from SCSDA research-centre work.
        </figcaption>
      </figure>
    </div>
  </section>
</BaseLayout>
