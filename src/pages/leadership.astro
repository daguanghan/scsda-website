---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "@data/site";
import { leadershipNetwork, leadershipResponsibilities } from "@data/research";
---

<BaseLayout
  title="Leadership"
  description="SCSDA's early platform construction is presented through formal founding leadership, research-centre development, collaboration, and applied project delivery."
>
  <section class="section">
    <div class="shell article narrow">
      <p class="eyebrow">Founding Leadership</p>
      <h2>Founding leadership and platform development.</h2>
      <p>
        SCSDA's early platform-construction period was initiated and led by
        Dr Daguang Han. The work covered institutional planning, research-centre
        development, international academic links, enterprise engagement, and
        the delivery of applied research projects.
      </p>
      <p>
        During this period, Dr Han served as founder and founding executive
        lead for the Academy's early research platform.
      </p>
    </div>
  </section>

  <section class="section surface">
    <div class="shell section-heading">
      <div>
        <p class="eyebrow">Leadership Structure</p>
        <h2>Founder, expert committee, research centres, and project collaboration.</h2>
      </div>
      <p>
        The Academy's platform was developed through founding leadership,
        expert engagement, research-centre coordination, project delivery, and
        collaboration with academic and enterprise partners.
      </p>
    </div>
    <div class="shell theme-grid">
      {leadershipNetwork.map((item) => (
        <article class="theme-card">
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="shell section-heading">
      <div>
        <p class="eyebrow">Founding Leadership Scope</p>
        <h2>Strategic, academic, and industry-facing responsibilities.</h2>
      </div>
      <p>
        Founding leadership is presented as platform-building work: agenda
        setting, centre formation, partner development, project formation,
        expert engagement, institutional reporting, and public communication.
      </p>
    </div>
    <div class="shell theme-grid">
      {leadershipResponsibilities.map((item) => (
        <article class="theme-card">
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section surface">
    <div class="shell article narrow">
      <p class="eyebrow">External References</p>
      <h2>Selected public reference links.</h2>
      <p>
        Selected public reference links are provided only for source
        transparency where founding leadership is discussed.
      </p>
      <div class="profile-links">
        {site.profiles.map((profile) => (
          <a href={profile.href} target="_blank" rel="noreferrer">{profile.label}</a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
