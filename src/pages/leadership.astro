---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "@data/site";
import { leadershipNetwork, leadershipResponsibilities } from "@data/research";
---

<BaseLayout
  title="Leadership"
  description="SCSDA was initiated and led by Dr Daguang Han during its platform-construction period, with responsibilities across strategic planning, research-centre development, collaboration, and applied project delivery."
>
  <section class="section">
    <div class="shell article narrow">
      <p class="eyebrow">Founding Leadership</p>
      <h2>Dr Daguang Han's role in building SCSDA.</h2>
      <p>
        SCSDA was initiated and led by Dr Daguang Han during the Academy's
        platform-construction period. His role covered institutional planning,
        research-centre development, international academic links, enterprise
        engagement, and the delivery of applied research projects.
      </p>
      <p>
        During this period, Dr Han served as founder, founding president, board
        chair, and executive lead for the Academy's early research platform.
      </p>
    </div>
  </section>

  <section class="section surface">
    <div class="shell section-heading">
      <div>
        <p class="eyebrow">Leadership Structure</p>
        <h2>Founder, expert committee, research centres, and project collaboration.</h2>
      </div>
      <p>
        The Academy's platform was developed through founding leadership,
        expert engagement, research-centre coordination, project delivery, and
        collaboration with academic and enterprise partners.
      </p>
    </div>
    <div class="shell theme-grid">
      {leadershipNetwork.map((item) => (
        <article class="theme-card">
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="shell section-heading">
      <div>
        <p class="eyebrow">Founding Leadership Scope</p>
        <h2>Strategic, academic, and industry-facing responsibilities.</h2>
      </div>
      <p>
        Dr Han's leadership is presented as platform-building work: agenda
        setting, centre formation, partner development, project formation,
        expert engagement, institutional reporting, and public communication.
      </p>
    </div>
    <div class="shell theme-grid">
      {leadershipResponsibilities.map((item) => (
        <article class="theme-card">
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section surface">
    <div class="shell article narrow">
      <p class="eyebrow">Public Profile Links</p>
      <h2>External academic profiles.</h2>
      <p>
        Selected academic profile links for Dr Han are provided for publication
        records, institutional affiliation, and external academic reference.
      </p>
      <div class="profile-affiliation" aria-label="Current academic affiliation">
        <span>Current academic affiliation</span>
        <strong>{site.academicAffiliation}</strong>
      </div>
      <div class="profile-links">
        {site.profiles.map((profile) => (
          <a href={profile.href} target="_blank" rel="noreferrer">{profile.label}</a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
